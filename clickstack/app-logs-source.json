  "defaultTableSelectExpression": "timestamp, level, message, method, path, status, duration",
  "serviceNameExpression": "boilerplate-app",
  "highlightedRowAttributeExpressions": [],
  "highlightedTraceAttributeExpressions": [],
  "materializedViews": []
}
